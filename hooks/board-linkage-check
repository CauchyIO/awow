#!/usr/bin/env bash
# PreToolUse hook (matcher: Skill) for the awow plugin.
#
# When an inner-loop engine's lifecycle skill is invoked (superpowers'
# brainstorming / writing-plans / verification-before-completion /
# requesting-code-review / finishing-a-development-branch), inject a single
# one-line board-linkage reminder so the board moves as a byproduct of the work.
#
# Non-blocking by design: it emits additionalContext only and NEVER denies the
# tool call. Scoped to adopted repos (those with .agents/AGENTS.md) so it stays
# silent everywhere else. The full crosswalk lives in
# .agents/skills/board-aware-development/SKILL.md.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
exec python3 "${SCRIPT_DIR}/board-linkage-check.py"
